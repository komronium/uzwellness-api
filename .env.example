PROJECT_NAME="UzWellness API"
API_PREFIX="/api"
ENVIRONMENT="local"
DEBUG=false

DATABASE_URL="postgresql+asyncpg://sanotour:sanotour@postgres:5432/sanotour"
TEST_DATABASE_URL="postgresql+asyncpg://sanotour:sanotour@localhost:5432/sanotour_test"
REDIS_URL="redis://redis:6379/0"
APP_DATABASE_URL="postgresql+asyncpg://sanotour:sanotour@postgres:5432/sanotour"
APP_REDIS_URL="redis://redis:6379/0"

JWT_SECRET_KEY="change-me-use-a-long-random-secret"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS='["http://localhost:3000","https://uzwellness.com","https://www.uzwellness.com"]'

INITIAL_SUPER_ADMIN_EMAIL="admin@uzwellness.com"
INITIAL_SUPER_ADMIN_PASSWORD="change-me"

UPLOAD_DIR="uploads"
UPLOAD_URL_PREFIX="/uploads"
MAX_UPLOAD_SIZE_MB=50
IMAGE_MAX_PIXELS=64000000
IMAGE_MAX_DIMENSION=1920
IMAGE_WEBP_QUALITY=85

PAYME_CHECKOUT_URL="https://checkout.paycom.uz/"
PAYME_MERCHANT_ID=""
PAYME_MERCHANT_KEY=""
CLICK_CHECKOUT_URL="https://my.click.uz/services/pay"
CLICK_SERVICE_ID=""
CLICK_MERCHANT_ID=""
CLICK_SECRET_KEY=""

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://api.uzwellness.com/api/auth/google/callback"
OAUTH_FRONTEND_REDIRECT_URL="https://uzwellness.com/auth/callback"

# EMAIL_BACKEND: "log" prints emails to the log; "smtp" actually sends.
# TimeWeb domain mailbox uses implicit SSL on port 465.
EMAIL_FROM="noreply@uzwellness.com"
EMAIL_BACKEND="log"
SMTP_HOST="smtp.timeweb.ru"
SMTP_PORT=465
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_USE_TLS=false
SMTP_USE_SSL=true

RATE_LIMIT_ENABLED=true
TRUSTED_PROXY_IPS='[]'

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=3600
