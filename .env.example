# Copy to .env.
# - Running the app via `docker compose up`: use service names (postgres, redis).
# - Running the app on the host (e.g. `uv run fastapi dev`): use localhost.

ENVIRONMENT=local
DEBUG=true

POSTGRES_USER=sanotour
POSTGRES_PASSWORD=sanotour
POSTGRES_DB=sanotour

DATABASE_URL=postgresql+asyncpg://sanotour:sanotour@postgres:5432/sanotour
TEST_DATABASE_URL=postgresql+asyncpg://sanotour:sanotour@postgres:5432/sanotour_test
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=["http://localhost:3000"]

INITIAL_SUPER_ADMIN_EMAIL=admin@example.com
INITIAL_SUPER_ADMIN_PASSWORD=use-a-strong-password
